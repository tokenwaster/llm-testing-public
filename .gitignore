.env
# machine-local operator prefs (saved serve port, …)
settings.local.json
# content-pipeline publish credentials (OAuth tokens, API keys) — never commit
secrets.local.json
studio/secrets.local.json
.venv/
.pw-browsers/
__pycache__/
*.pyc
.pytest_cache/
# reports/ are pure functions of runs/ — regenerate any time (harness report)
reports/
# runs/ and archive/ ARE tracked: immutable ground-truth benchmark data

# model-watch polling state (regenerable; NEW/FADING is machine-local)
watch/

# generated video/b-roll assets (large binaries; regenerable from runs/)
assets/

# scout triage — throwaway go/no-go screens, never part of the dataset
scouts/

# the PUBLIC working copy — its own git repo (harness publish writes it).
# Never track it here: it would duplicate 33k files and entangle the two repos.
dist/
